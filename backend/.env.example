# Server port
PORT=8080

# CORS config (comma separated list)
ALLOWED_ORIGINS=http://localhost:3000

# Rate limits config
RATE_LIMIT_RATE=5.0
RATE_LIMIT_BURST=10

# Max playlist size cap (prevents resource-exhaustion attacks)
MAX_PLAYLIST_SIZE=500

# Max concurrent yt-dlp subprocess invocations (protect VPS alongside FFmpeg services)
MAX_CONCURRENT_YTDLP=4

# Directory for temporary downloads storage
TEMP_DIR=./downloads_temp

# System path or binary location for yt-dlp
YTDLP_PATH=yt-dlp

# Optional: Path to raw cookies text file (for bypassing YouTube 429 errors)
# YOUTUBE_COOKIES_PATH=/path/to/cookies.txt

# Optional: HTTP/HTTPS proxy URL (for bypassing YouTube 429 rate limits)
# HTTP_PROXY=http://user:pass@proxyhost:port
# HTTPS_PROXY=http://user:pass@proxyhost:port
